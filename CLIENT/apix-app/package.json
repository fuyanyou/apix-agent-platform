{
  "name": "apix-app",
  "version": "1.0.0",
  "description": "APIX Client",
  "main": "./out/main/index.js",
  "author": "https://github.com/JJJJSTIYYYY",
  "homepage": "",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "electron:generate-icons": "electron-icon-builder --input=./resources/APIX.png --output=build --flatten"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@fsegurai/codemirror-theme-github-light": "^6.2.5",
    "axios": "^1.13.5",
    "cherry-markdown": "^0.10.3",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "element-plus": "^2.11.2",
    "fast-diff": "^1.3.0",
    "fast-glob": "^3.3.3",
    "form-data": "^4.0.5",
    "github-markdown-css": "^5.8.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.0",
    "markdown-it-link-attributes": "^4.0.1",
    "mica-electron": "^1.5.16",
    "node-fetch": "^3.3.2",
    "pinia": "^3.0.3",
    "trash": "^10.1.1",
    "vue-router": "^4.5.1",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.0.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "electron": "^37.10.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "^10.3.0",
    "naive-ui": "^2.43.1",
    "prettier": "^3.6.2",
    "sass-embedded": "^1.97.1",
    "unplugin-auto-import": "^20.1.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^7.0.5",
    "vue": "^3.5.17",
    "vue-eslint-parser": "^10.2.0"
  },
  "build": {
    "appId": "com.justiy.apix",
    "productName": "ApiX",
    "win": {
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "icon": "build/icons/icon.icns"
    },
    "linux": {
      "icon": "build/icons/"
    }
  },
  "volta": {
    "node": "22.19.0"
  }
}
